# MCP 伺服器環境變量配置
# 複製此文件為 .env 並填入實際值

# GitHub MCP Server 配置
GITHUB_TOKEN=your_github_fine_grained_token_here

# Tavily MCP Server 配置  
TAVILY_API_KEY=your_tavily_api_key_here

# PostgreSQL 數據庫配置
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_USER=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=betweencoffee_delivery_db

# 其他環境變量（可選）
# PYTHONIOENCODING=utf-8

# 使用說明：
# 1. 複製此文件：cp .env.example .env
# 2. 編輯 .env 文件，填入實際的 token 和密碼
# 3. 確保 .env 在 .gitignore 中，不會被提交到版本控制
# 4. 系統會自動讀取 .env 文件中的環境變量