{
    "mcpServers": {
        "mcp-installer": {
            "command": "npx",
            "args": ["@anaisbetts/mcp-installer"]
        },
        "mcp-server-fetch": {
            "command": "/home/kei/snap/code/229/.local/share/../bin/uvx",
            "args": ["mcp-server-fetch"]
        },
        "simple-postgres": {
            "command": "node",
            "args": [
                "/home/kei/Desktop/betweencoffee_delivery_enhance/simple-postgres-mcp-fixed-v2.js"
            ],
            "env": {
                "POSTGRES_URL": "postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/betweencoffee_delivery_db",
                "POSTGRES_USER": "postgres",
                "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}",
                "POSTGRES_HOST": "localhost",
                "POSTGRES_PORT": "5432",
                "POSTGRES_DB": "betweencoffee_delivery_db"
            }
        },
        "mcp-server-filesystem": {
            "command": "npx",
            "args": ["@modelcontextprotocol/server-filesystem", "/home/kei/Desktop/betweencoffee_delivery_enhance"]
        },
        "mcp-server-github": {
            "command": "npx",
            "args": ["@iflow-mcp/server-github"],
            "env": {
                "GITHUB_TOKEN": "${GITHUB_TOKEN}"
            }
        },
        "simple-tavily-search": {
            "command": "node",
            "args": [
                "/home/kei/Desktop/betweencoffee_delivery_enhance/simple-tavily-mcp-fixed.js"
            ],
            "env": {
                "TAVILY_API_KEY": "${TAVILY_API_KEY}",
                "PYTHONIOENCODING": "utf-8"
            },
            "inputs": {
                "api_key": "${TAVILY_API_KEY}"
            }
        },
        "redis-mcp": {
            "command": "node",
            "args": [
                "/home/kei/Desktop/betweencoffee_delivery_enhance/node_modules/@gongrzhe/server-redis-mcp/build/index.js",
                "redis://localhost:6379"
            ]
        }
    }
}