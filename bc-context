#!/bin/bash
# Between Coffee 上下文加載器 - 簡化版本
# 用法: bc-context [load|status|test|help]

set -e

# 配置
PROJECT_DIR="/home/kei/Desktop/betweencoffee_delivery_enhance"
CONTEXT_FILE="/tmp/betweencoffee_context_current.txt"
LOG_FILE="/tmp/bc_context.log"

# 顏色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 日誌函數
log() {
    echo -e "${BLUE}[bc-context]${NC} $1" | tee -a "$LOG_FILE"
}

success() {
    echo -e "${GREEN}✓${NC} $1" | tee -a "$LOG_FILE"
}

warn() {
    echo -e "${YELLOW}⚠${NC} $1" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${RED}✗${NC} $1" | tee -a "$LOG_FILE"
}

# 檢查項目
check_project() {
    if [ ! -d "$PROJECT_DIR" ]; then
        error "項目目錄不存在: $PROJECT_DIR"
        return 1
    fi
    cd "$PROJECT_DIR" || return 1
    return 0
}

# 加載上下文
load_context() {
    log "加載 Between Coffee 上下文..."
    
    if ! check_project; then
        return 1
    fi
    
    if [ ! -f "load_betweencoffee_context.py" ]; then
        error "加載腳本不存在"
        return 1
    fi
    
    # 運行加載
    python load_betweencoffee_context.py --output "$CONTEXT_FILE"
    
    if [ $? -eq 0 ] && [ -f "$CONTEXT_FILE" ]; then
        FILE_SIZE=$(wc -c < "$CONTEXT_FILE")
        FILE_SIZE_KB=$((FILE_SIZE / 1024))
        
        success "上下文加載成功!"
        log "文件: $CONTEXT_FILE"
        log "大小: ${FILE_SIZE_KB} KB (~$((FILE_SIZE/4660*1165)) tokens)"
        
        # 設置環境變量
        export BETWEENCOFFEE_CONTEXT_FILE="$CONTEXT_FILE"
        export BETWEENCOFFEE_CONTEXT_LOADED="true"
        
        # 顯示摘要
        echo ""
        echo "📋 上下文摘要:"
        echo "├── 項目規範 (.clinerules)"
        echo "├── 技術架構: Django + PostgreSQL + WebSocket"
        echo "├── 系統狀態: 穩定，核心功能完整"
        echo "├── 優先任務: ID重複、WebSocket穩定性、移動端優化"
        echo "└── 大小: ${FILE_SIZE_KB} KB"
        
        return 0
    else
        error "加載失敗"
        return 1
    fi
}

# 檢查狀態
check_status() {
    log "檢查上下文狀態..."
    
    if [ -f "$CONTEXT_FILE" ]; then
        FILE_SIZE=$(wc -c < "$CONTEXT_FILE")
        FILE_SIZE_KB=$((FILE_SIZE / 1024))
        MOD_TIME=$(stat -c %y "$CONTEXT_FILE" 2>/dev/null || echo "未知")
        
        success "上下文文件存在"
        echo "├── 路徑: $CONTEXT_FILE"
        echo "├── 大小: ${FILE_SIZE_KB} KB"
        echo "├── 修改時間: $MOD_TIME"
        echo "└── 環境變量: ${BETWEENCOFFEE_CONTEXT_LOADED:-未設置}"
        
        # 檢查內容
        if grep -q "項目規範 (.clinerules)" "$CONTEXT_FILE"; then
            success "內容驗證: 包含 .clinerules"
        else
            warn "內容驗證: 缺少 .clinerules"
        fi
        
        if grep -q "Between Coffee 系統 - 上下文摘要" "$CONTEXT_FILE"; then
            success "內容驗證: 包含 Memory Bank"
        else
            warn "內容驗證: 缺少 Memory Bank"
        fi
        
        return 0
    else
        warn "上下文文件不存在"
        echo "使用 'bc-context load' 加載上下文"
        return 1
    fi
}

# 測試功能
test_context() {
    log "測試上下文功能..."
    
    # 測試1: 檢查項目
    if check_project; then
        success "測試1: 項目目錄檢查通過"
    else
        error "測試1: 項目目錄檢查失敗"
        return 1
    fi
    
    # 測試2: 檢查腳本
    if [ -f "$PROJECT_DIR/load_betweencoffee_context.py" ]; then
        success "測試2: 加載腳本存在"
    else
        error "測試2: 加載腳本不存在"
        return 1
    fi
    
    # 測試3: 加載上下文
    TEMP_FILE="/tmp/bc_test_$(date +%s).txt"
    cd "$PROJECT_DIR" && python load_betweencoffee_context.py --output "$TEMP_FILE" --summary-only
    
    if [ $? -eq 0 ] && [ -f "$TEMP_FILE" ]; then
        FILE_SIZE=$(wc -c < "$TEMP_FILE")
        if [ "$FILE_SIZE" -gt 1000 ]; then
            success "測試3: 上下文生成成功 (${FILE_SIZE} 字符)"
        else
            warn "測試3: 上下文大小異常 (${FILE_SIZE} 字符)"
        fi
        rm -f "$TEMP_FILE"
    else
        error "測試3: 上下文生成失敗"
        return 1
    fi
    
    # 測試4: 檢查 .clinerules
    if [ -f "$PROJECT_DIR/.clinerules" ]; then
        CLINERULES_SIZE=$(wc -c < "$PROJECT_DIR/.clinerules")
        success "測試4: .clinerules 存在 (${CLINERULES_SIZE} 字符)"
    else
        error "測試4: .clinerules 不存在"
        return 1
    fi
    
    success "所有測試通過!"
    return 0
}

# 清理舊文件
cleanup() {
    log "清理舊的上下文文件..."
    
    # 刪除超過1天的文件
    OLD_COUNT=$(find /tmp -name "betweencoffee_context_*.txt" -mtime +1 -delete 2>/dev/null | wc -l)
    
    # 刪除超過7天的日誌
    find /tmp -name "bc_context.log" -mtime +7 -delete 2>/dev/null
    
    success "清理完成，刪除了 $OLD_COUNT 個舊文件"
}

# 顯示幫助
show_help() {
    echo "Between Coffee 上下文加載器 (bc-context)"
    echo ""
    echo "用法:"
    echo "  bc-context load     加載項目上下文"
    echo "  bc-context status   檢查上下文狀態"
    echo "  bc-context test     測試功能"
    echo "  bc-context cleanup  清理舊文件"
    echo "  bc-context help     顯示幫助"
    echo ""
    echo "示例:"
    echo "  bc-context load     # 加載上下文"
    echo "  bc-context status   # 檢查狀態"
    echo "  bc-context test     # 測試功能"
    echo ""
    echo "環境變量:"
    echo "  BETWEENCOFFEE_CONTEXT_FILE    上下文文件路徑"
    echo "  BETWEENCOFFEE_CONTEXT_LOADED  加載狀態"
    echo ""
    echo "提示:"
    echo "  - 上下文加載後，Cline 可以訪問項目信息"
    echo "  - 建議在開始新任務前加載上下文"
    echo "  - 定期清理舊文件以節省空間"
}

# 主函數
main() {
    local action="${1:-help}"
    
    case "$action" in
        load|--load)
            load_context
            ;;
        status|--status)
            check_status
            ;;
        test|--test)
            test_context
            ;;
        cleanup|--cleanup)
            cleanup
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            error "未知命令: $action"
            show_help
            return 1
            ;;
    esac
    
    return $?
}

# 執行
main "$@"